# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# NHGIS API key — get a free key at https://account.ipums.org/api_keys
NHGIS_API_KEY=your_key_here

# RDH (Redistricting Data Hub) credentials — for VEST precinct shapefile downloads
# Request "API Download user" access at info@redistrictingdatahub.org
# Docs: https://github.com/nonpartisan-redistricting-datahub/api
RDH_USERNAME=your_rdh_email@example.com
RDH_PASSWORD=your_rdh_password

# Feedback form (web/src/routes/feedback) — used by the SvelteKit server route
# Add these to Cloudflare Pages > Settings > Environment Variables as well
TURNSTILE_SITE_KEY=0x4AAAAAACvo9eAug0OpeMuc
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
RESEND_API_KEY=your_resend_api_key
